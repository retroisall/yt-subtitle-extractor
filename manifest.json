{
  "manifest_version": 3,
  "name": "YT Subtitle Demo",
  "version": "1.0",
  "description": "自動提取 YouTube 字幕並同步顯示",
  "permissions": [],
  "host_permissions": ["*://www.youtube.com/*"],
  "content_scripts": [
    {
      "matches": ["*://www.youtube.com/*"],
      "js": ["patch.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["*://www.youtube.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["inject.js"],
      "matches": ["*://www.youtube.com/*"]
    }
  ]
}